<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo">

    <FrameLayout
        android:id="@+id/contenedor_fragmentos_principal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnNavContainer" />

    <LinearLayout
        android:id="@+id/btnNavContainer"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_nav_redondeado"
        android:elevation="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:outlineProvider="background"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:src="@drawable/icn_home"
            app:tint="@color/color_texto_blanco" />

        <ImageView
            android:id="@+id/navCarta"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:src="@drawable/icn_menu_lista"
            app:tint="@color/color_texto_blanco" />

        <ImageView
            android:id="@+id/navCarrito"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:src="@drawable/icn_carrito"
            app:tint="@color/color_texto_blanco" />

        <ImageView
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="35dp"
            android:layout_weight="1"
            android:src="@drawable/icn_perfil"
            app:tint="@color/color_texto_blanco" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
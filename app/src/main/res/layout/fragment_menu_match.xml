<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo">

    <ImageView
        android:id="@+id/btnNotificaciones"
        android:layout_width="40dp"
        android:layout_height="37dp"
        android:layout_marginEnd="40dp"
        android:src="@drawable/icn_notificacion"
        app:layout_constraintBottom_toBottomOf="@id/tvNombreApp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvNombreApp"
        app:layout_constraintVertical_bias="1.0"
        app:tint="#E0C097" />

    <ImageView
        android:id="@+id/imgLogoToolbar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/logo_pincana_v2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvNombreApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Picaña Grill"
        android:textColor="#E0C097"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/imgLogoToolbar"
        app:layout_constraintStart_toEndOf="@id/imgLogoToolbar"
        app:layout_constraintTop_toTopOf="@id/imgLogoToolbar"
        app:layout_constraintVertical_bias="0.555" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardPlato"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="32dp"
        app:cardBackgroundColor="#212121"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgLogoToolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/imgPlato"
                android:layout_width="381dp"
                android:layout_height="783dp"
                android:scaleType="centerCrop"
                android:src="@drawable/img_plato_ejemplo"
                tools:layout_editor_absoluteX="0dp"
                tools:layout_editor_absoluteY="-20dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:background="@drawable/degradado_negro_transparente"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/tvTagNuevo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="8dp"
                android:text="Nuevo"
                android:textColor="#FFD700"
                android:textSize="16sp"
                android:textStyle="italic"
                app:layout_constraintBottom_toTopOf="@+id/tvNombrePlato"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvNombrePlato"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="110dp"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="Picaña Tradicional" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageButton
                    android:id="@+id/btnRechazar"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_boton_circular_oscuro"
                    android:src="@drawable/icn_cerrar"
                    app:tint="#E91E63" />

                <ImageButton
                    android:id="@+id/btnSuperLike"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_boton_circular_oscuro"
                    android:src="@drawable/icn_estrella"
                    app:tint="#4CAF50" />

                <ImageButton
                    android:id="@+id/btnLike"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_boton_circular_oscuro"
                    android:src="@drawable/icn_corazon"
                    app:tint="#F44336" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>